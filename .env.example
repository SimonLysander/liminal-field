# ── Liminal Field 环境配置 ──
# 复制为 .env 后按需修改，不要提交到 git

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=liminal-field

# 阿里云 OSS（V2，替代 MinIO）
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=lux-stirring

# Knowledge Base（本地开发用相对路径，Docker 用绝对路径）
CONTENT_REPO_ROOT=./liminal-field-kb

# Auth
JWT_SECRET=changeme
ADMIN_PASSWORD=changeme

# MinerU（可选，留空则导入功能不可用）
MINERU_TOKEN=

# ── 以下仅 Docker 部署时需要修改 ──
# Docker 中 MongoDB 的 host 是容器名，不是 localhost：
#   MONGO_HOST=mongo
#   CONTENT_REPO_ROOT=/data/liminal-field-kb

# Knowledge Base Git 远端（可选）。Docker：`.env` + `docker compose up`。
# 推荐拆成两项（classic / fine-grained PAT 都填在 KB_GIT_TOKEN，勿提交）：
# KB_REMOTE_URL=https://github.com/<org>/<repo>.git
# KB_GIT_TOKEN=ghp_... 或 github_pat_...
# GIT_SYNC_CRON=0 3 * * *
# CONTENT_GIT_AUTHOR_NAME=Liminal Field
# CONTENT_GIT_AUTHOR_EMAIL=no-reply@liminal-field.local
#
# 或整条 HTTPS（已含 x-access-token）：只设 KB_REMOTE_URL、不要重复设 KB_GIT_TOKEN。
# 自动拼接仅支持 host 为 github.com；企业版请把凭证直接写进 KB_REMOTE_URL。
#
# git@：容器内需自备 SSH 密钥（在 docker-compose.yml 的 server.volumes 自行挂载 ~/.ssh 等）。
# 不配 KB_REMOTE_URL 则 KB 仅在 Docker 卷 kb-data 里本地 Git，不连远程。
