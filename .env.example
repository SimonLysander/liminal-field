# ── Liminal Field Docker 部署配置 ──
# 复制为 .env 后按需修改

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=change-me-mongo-password
MONGO_DATABASE=liminal-field

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=change-me-minio-password
MINIO_BUCKET=draft-assets

# Server
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
ADMIN_PASSWORD=change-me-admin-password

# Knowledge Base Git 远端（可选）
# 配了则首次启动自动 clone，后续自动 push 同步
# 不配则本地初始化空仓库，数据只在 Docker volume 中
# KB_REMOTE_URL=https://github.com/yourname/liminal-field-kb.git

# Git 定时同步 cron（默认每天凌晨 3 点）
# GIT_SYNC_CRON=0 3 * * *

# Git 提交作者信息
# CONTENT_GIT_AUTHOR_NAME=Liminal Field
# CONTENT_GIT_AUTHOR_EMAIL=no-reply@liminal-field.local
