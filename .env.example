# ── Liminal Field 环境配置 ──
# 复制为 .env 后按需修改，不要提交到 git

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=liminal-field

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=draft-assets

# Knowledge Base（本地开发用相对路径，Docker 用绝对路径）
CONTENT_REPO_ROOT=./liminal-field-kb

# Auth
JWT_SECRET=changeme
ADMIN_PASSWORD=changeme

# MinerU（可选，留空则导入功能不可用）
MINERU_TOKEN=

# ── 以下仅 Docker 部署时需要修改 ──
# Docker 中 MongoDB/MinIO 的 host 是容器名，不是 localhost：
#   MONGO_HOST=mongo
#   MINIO_HOST=minio
#   CONTENT_REPO_ROOT=/data/liminal-field-kb

# Knowledge Base Git 远端（可选）
# KB_REMOTE_URL=https://github.com/yourname/liminal-field-kb.git
# GIT_SYNC_CRON=0 3 * * *
# CONTENT_GIT_AUTHOR_NAME=Liminal Field
# CONTENT_GIT_AUTHOR_EMAIL=no-reply@liminal-field.local
