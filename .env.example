# ── Liminal Field 环境配置 ──
# 复制为 .env 后按需修改，不要提交到 git

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=liminal-field

# 阿里云 OSS
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=lux-stirring

# Knowledge Base（本地开发用相对路径，Docker 用绝对路径）
CONTENT_REPO_ROOT=./liminal-field-kb

# Auth
JWT_SECRET=changeme
ADMIN_PASSWORD=changeme

# ── 以下仅 Docker 部署时需要修改 ──
# Docker 中 MongoDB 的 host 是容器名，不是 localhost：
#   MONGO_HOST=mongo
#   CONTENT_REPO_ROOT=/data/liminal-field-kb
#
# 以下配置已迁移到 Settings UI（存 MongoDB），不再需要在 env 中设置：
# - 远端仓库：KB_REMOTE_URL / KB_GIT_TOKEN
# - Git 署名：CONTENT_GIT_AUTHOR_NAME / CONTENT_GIT_AUTHOR_EMAIL
# - 自动同步：GIT_SYNC_CRON
# - MinerU：MINERU_TOKEN
