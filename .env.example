# ── Liminal Field 环境配置 ──
# 复制为 .env 后填入真实值，不要提交到 git。
#
# 归属准则见 CLAUDE.md「配置归属准则」：本文件只放「部署级 / 机密 / 基础设施」配置
# （换部署才变、应用没它起不来、运维管）。业务配置——远端同步(remoteUrl/gitToken/
# gitAuthor*/gitSyncCron)、MinerU token、AI providers、owner、agent——在 Settings UI
# 配置并存入 Mongo，**不在这里设**。

# ── MongoDB（基础设施）──
MONGO_HOST=localhost          # Docker 部署时填容器名：mongo
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=liminal-field

# ── 阿里云 OSS（对象存储凭证）──
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=lux-stirring
OSS_INTERNAL=false            # 服务器在同区阿里云内网时设 true（走内网 endpoint 省流量）

# ── Knowledge Base 本地归档路径 ──
CONTENT_REPO_ROOT=./liminal-field-kb   # Docker 部署时填：/data/liminal-field-kb

# ── Auth（机密）──
JWT_SECRET=changeme
ADMIN_PASSWORD=changeme
COOKIE_SECURE=                # HTTPS 部署时设 true（cookie 仅经 https 传输）

# ── 站点域名（Caddy 自动 HTTPS 用）──
SITE_DOMAIN=localhost         # 有域名填域名；无域名 / 纯 HTTP 填 :80

# ── 系统内部容错定时（管理员无需调，留空用代码默认 0 3 * * *）──
# GIT_ARCHIVE_RETRY_CRON=0 3 * * *

# ── RSSHub（RSS 聚合代理）──
# Docker Compose 内部访问，无需改动；本地开发可指向公共实例或自建实例
# RSSHUB_BASE_URL=http://rsshub:1200
